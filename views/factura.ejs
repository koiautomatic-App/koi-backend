<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>KOI-FACTURA | Comprobante Electrónico</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background: #0A0A0C;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      padding: 48px 24px;
      line-height: 1.5;
      min-height: 100vh;
    }

    .invoice-container {
      max-width: 560px;
      margin: 0 auto;
      background: #111114;
      border-radius: 20px;
      overflow: hidden;
      border: 0.5px solid rgba(255,255,255,0.08);
    }

    /* Accent line top — naranja a verde, igual que el dashboard KOI */
    .accent-bar {
      height: 3px;
      background: linear-gradient(90deg, #F97316 0%, #22C55E 100%);
    }

    /* ── HEADER ── */
    .header {
      padding: 28px 32px 24px;
      background: #0D0D10;
      border-bottom: 0.5px solid rgba(255,255,255,0.07);
    }

    .header-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
    }

    .brand-row {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .logo-box {
      width: 44px;
      height: 44px;
      background: #1A1A1F;
      border-radius: 11px;
      border: 0.5px solid rgba(255,255,255,0.1);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      overflow: hidden;
    }

    .logo-box img {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }

    .logo-fallback {
      font-size: 18px;
      font-weight: 800;
      color: #F97316;
      letter-spacing: -0.5px;
    }

    .empresa-nombre {
      font-size: 17px;
      font-weight: 700;
      color: #F9FAFB;
      letter-spacing: -0.3px;
      line-height: 1.2;
    }

    .empresa-sub {
      font-size: 12px;
      color: #4B5563;
      margin-top: 3px;
    }

    /* ── META (nro + fecha) ── */
    .meta-band {
      padding: 18px 32px;
      background: #0F0F13;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 16px;
      border-bottom: 0.5px solid rgba(255,255,255,0.07);
    }

    .meta-item { }

    .meta-label {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #374151;
      margin-bottom: 5px;
    }

    .meta-val {
      font-size: 14px;
      font-weight: 600;
      color: #F9FAFB;
    }

    .meta-item.right { text-align: right; }

    /* ── DESTINATARIO ── */
    .dest-band {
      padding: 18px 32px;
      border-bottom: 0.5px solid rgba(255,255,255,0.07);
    }

    .dest-name {
      font-size: 15px;
      font-weight: 600;
      color: #F9FAFB;
    }

    .dest-msg {
      font-size: 13px;
      color: #6B7280;
      margin-top: 5px;
      padding-left: 12px;
      border-left: 2px solid #F97316;
    }

    /* ── TABLA PRODUCTOS ── */
    .productos-band {
      padding: 20px 32px;
      border-bottom: 0.5px solid rgba(255,255,255,0.07);
    }

    .section-label {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #374151;
      margin-bottom: 14px;
    }

    .productos-tabla {
      width: 100%;
      border-collapse: collapse;
    }

    .productos-tabla th {
      text-align: left;
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #374151;
      padding-bottom: 10px;
      border-bottom: 0.5px solid rgba(255,255,255,0.07);
    }

    .productos-tabla th:not(:first-child) { text-align: right; }

    .productos-tabla td {
      padding: 11px 0;
      font-size: 13px;
      color: #D1D5DB;
      border-bottom: 0.5px solid rgba(255,255,255,0.04);
      vertical-align: top;
      line-height: 1.5;
    }

    .productos-tabla td:not(:first-child) { text-align: right; white-space: nowrap; }
    .productos-tabla td.subtotal-cell { color: #F9FAFB; font-weight: 600; }
    .productos-tabla tr:last-child td { border-bottom: none; }

    /* ── IVA (solo Factura A) ── */
    .iva-band {
      padding: 14px 32px;
      background: #0D0D10;
      border-bottom: 0.5px solid rgba(255,255,255,0.07);
      display: flex;
      justify-content: flex-end;
      gap: 40px;
    }

    .iva-item { text-align: right; }
    .iva-label { font-size: 9px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #374151; margin-bottom: 4px; }
    .iva-val { font-size: 13px; font-weight: 500; color: #9CA3AF; }

    /* ── TOTAL ── */
    .total-band {
      padding: 20px 32px;
      background: #0D0D10;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 0.5px solid rgba(255,255,255,0.07);
    }

    .total-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #4B5563;
    }

    .total-amount {
      font-size: 30px;
      font-weight: 800;
      color: #F9FAFB;
      letter-spacing: -0.04em;
      line-height: 1;
    }

    .total-amount .currency {
      font-size: 17px;
      font-weight: 600;
      color: #F97316;
      vertical-align: super;
      margin-right: 2px;
    }

    .total-amount .cents {
      font-size: 16px;
      font-weight: 500;
      color: #6B7280;
    }

    /* ── AFIP / QR ── */
    .afip-band {
      padding: 20px 32px;
      display: flex;
      align-items: center;
      gap: 20px;
      border-bottom: 0.5px solid rgba(255,255,255,0.07);
    }

    .qr-wrapper {
      flex-shrink: 0;
      width: 80px;
      height: 80px;
      background: #ffffff;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .qr-wrapper img { width: 100%; height: 100%; object-fit: contain; }

    .qr-placeholder {
      font-size: 9px;
      font-weight: 700;
      color: #9CA3AF;
      text-align: center;
      line-height: 1.4;
      letter-spacing: 0.05em;
    }

    .afip-info { flex: 1; }

    .afip-section-label {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #F97316;
      margin-bottom: 7px;
    }

    .cae-num {
      font-size: 15px;
      font-weight: 700;
      color: #F9FAFB;
      letter-spacing: -0.02em;
      margin-bottom: 4px;
    }

    .cae-vto {
      font-size: 12px;
      color: #4B5563;
      margin-bottom: 10px;
    }

    .afip-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(34,197,94,0.08);
      border: 0.5px solid rgba(34,197,94,0.2);
      border-radius: 100px;
      padding: 4px 10px;
    }

    .badge-dot {
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: #22C55E;
      flex-shrink: 0;
    }

    .badge-text {
      font-size: 10px;
      font-weight: 600;
      color: #4ADE80;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    /* ── CTA ── */
    .cta-band {
      padding: 20px 32px;
      border-bottom: 0.5px solid rgba(255,255,255,0.07);
    }

    .btn-descarga {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      width: 100%;
      padding: 14px 24px;
      background: linear-gradient(90deg, #F97316 0%, #FB923C 100%);
      color: #fff;
      border: none;
      border-radius: 10px;
      font-family: 'Inter', sans-serif;
      font-size: 14px;
      font-weight: 700;
      letter-spacing: 0.03em;
      cursor: pointer;
      text-decoration: none;
    }

    .btn-descarga svg { flex-shrink: 0; }

    /* ── FOOTER ── */
    .footer {
      padding: 16px 32px;
      background: #080809;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .footer-brand {
      font-size: 11px;
      font-weight: 800;
      color: #F97316;
      letter-spacing: 0.08em;
    }

    .footer-legal {
      font-size: 10px;
      color: #1F2937;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 600px) {
      body { padding: 0; background: #0A0A0C; }
      .invoice-container { border-radius: 0; border-left: none; border-right: none; }
      .meta-band, .dest-band, .productos-band, .total-band,
      .afip-band, .cta-band, .header, .footer { padding-left: 20px; padding-right: 20px; }
      .afip-band { flex-direction: column; align-items: flex-start; }
      .total-amount { font-size: 24px; }
    }

    /* ── PRINT ── */
    @media print {
      body { background: #0A0A0C; padding: 0; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .invoice-container { border-radius: 0; box-shadow: none; max-width: 100%; }
      .btn-descarga { display: none; }
      .cta-band { display: none; }
    }
  </style>
</head>
<body>
  <div class="invoice-container">

    <div class="accent-bar"></div>

    <!-- HEADER -->
    <div class="header">
      <div class="header-inner">
        <div class="brand-row">
          <div class="logo-box">
            <% if (logoUrl && logoUrl !== '') { %>
              <img src="<%= logoUrl %>" alt="Logo">
            <% } else { %>
              <span class="logo-fallback">K</span>
            <% } %>
          </div>
          <div>
            <div class="empresa-nombre"><%= nombreFantasia %></div>
            <div class="empresa-sub"><%= razonSocial %> &nbsp;·&nbsp; CUIT <%= cuitFmt %></div>
          </div>
        </div>
      </div>
    </div>

    <!-- COMPROBANTE + FECHA -->
    <div class="meta-band">
      <div class="meta-item">
        <div class="meta-label">Comprobante</div>
        <div class="meta-val"><%= tipoFactura %> Nº <%= nroComp %></div>
      </div>
      <div class="meta-item right">
        <div class="meta-label">Fecha</div>
        <div class="meta-val"><%= fecha %></div>
      </div>
    </div>

    <!-- DESTINATARIO -->
    <div class="dest-band">
      <div class="dest-name">Estimado/a <strong><%= customerName %></strong></div>
      <div class="dest-msg">Adjuntamos el comprobante correspondiente a tu compra.</div>
    </div>

    <!-- DETALLE PRODUCTOS -->
    <div class="productos-band">
      <div class="section-label">Detalle</div>
      <table class="productos-tabla">
        <thead>
          <tr>
            <th>Producto</th>
            <th>Cant</th>
            <th>Precio</th>
            <th>Subtotal</th>
          </tr>
        </thead>
        <tbody>
          <%- filasItems %>
        </tbody>
      </table>
    </div>

    <!-- IVA DISCRIMINADO (solo Factura A) -->
    <% if (tipoFactura === 'FACTURA A' && impNeto && impIVA) { %>
    <div class="iva-band">
      <div class="iva-item">
        <div class="iva-label">Subtotal</div>
        <div class="iva-val">$ <%= impNeto %></div>
      </div>
      <div class="iva-item">
        <div class="iva-label">IVA 21%</div>
        <div class="iva-val">$ <%= impIVA %></div>
      </div>
    </div>
    <% } %>

    <!-- TOTAL -->
    <div class="total-band">
      <div class="total-label">Total a pagar</div>
      <div class="total-amount">
        <span class="currency">$</span><%= total %>
      </div>
    </div>

    <!-- QR + CAE -->
    <div class="afip-band">
      <div class="qr-wrapper">
        <% if (qrImageHtml) { %>
          <%- qrImageHtml %>
        <% } else { %>
          <div class="qr-placeholder">QR<br>AFIP</div>
        <% } %>
      </div>
      <div class="afip-info">
        <div class="afip-section-label">Validación AFIP</div>
        <div class="cae-num"><%= caeDisplay %></div>
        <div class="cae-vto">Vencimiento: <%= caeVto %></div>
        <div class="afip-badge">
          <div class="badge-dot"></div>
          <div class="badge-text">Comprobante autorizado</div>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="cta-band">
      <button onclick="window.print(); return false;" class="btn-descarga">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M8 2v8M5 7l3 3 3-3M2 13h12" stroke="#fff" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Imprimir / Guardar PDF
      </button>
    </div>

    <!-- FOOTER -->
    <div class="footer">
      <span class="footer-brand">KOI-FACTURA</span>
      <span class="footer-legal">Sistema de Facturación Electrónica</span>
    </div>

  </div>
</body>
</html>
