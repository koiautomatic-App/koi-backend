<!-- views/reporte.ejs -->
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<title>Reporte Mensual - <%= nombreMes %></title>
<style>
  body, table, td { -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
  table { border-collapse: collapse !important; }
  body { margin:0; padding:0; width:100% !important; }
  @media only screen and (max-width: 600px) {
    .koi-wrapper { width: 100% !important; }
    .koi-stat-cell { display:block !important; width:100% !important; border-right:none !important; padding:0 0 10px 0 !important; margin-bottom:10px !important; border-bottom:1px solid #eee !important; }
    .koi-stat-cell:last-child { border-bottom:none !important; margin-bottom:0 !important; padding-bottom:0 !important; }
    .koi-px { padding-left:16px !important; padding-right:16px !important; }
  }
</style>
</head>
<body style="margin:0;padding:0;background-color:#eef0f4;font-family:'Segoe UI', Arial, Helvetica, sans-serif;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#eef0f4;">
<tr>
<td align="center" style="padding:24px 12px;">

<table role="presentation" class="koi-wrapper" width="600" cellpadding="0" cellspacing="0" border="0" style="width:600px;max-width:600px;background-color:#ffffff;border-radius:10px;overflow:hidden;">

  <!-- ================= HEADER ================= -->
  <tr>
    <td class="koi-px" style="background-color:#0e1119;padding:10px 16px;">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
          <td valign="middle">
            <table role="presentation" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td valign="middle">
                  <table role="presentation" width="24" height="24" cellpadding="0" cellspacing="0" border="0" style="background-color:#ff6b00;border-radius:6px;">
                    <tr><td align="center" valign="middle" style="color:#ffffff;font-size:11px;font-weight:800;font-family:Arial, sans-serif;">K</td></tr>
                  </table>
                </td>
                <td valign="middle" style="padding-left:8px;">
                  <div style="font-size:12px;font-weight:700;color:#ffffff;font-family:Arial, sans-serif;letter-spacing:-0.3px;">KOI<span style="color:#ff6b00;">&middot;FACTURA</span></div>
                </td>
              </tr>
            </table>
          </td>
          <td valign="middle" align="right" style="color:#555555;font-size:10px;font-family:Arial, sans-serif;white-space:nowrap;">
            Reporte autom&aacute;tico mensual
          </td>
        </tr>
      </table>
    </td>
  </tr>

  <!-- ================= TITLE ================= -->
  <tr>
    <td class="koi-px" style="padding:10px 16px;border-bottom:1px solid #f0ede8;">
      <div style="font-size:16px;font-weight:700;color:#111111;font-family:Arial, sans-serif;letter-spacing:-0.3px;margin-bottom:2px;">Reporte de <%= nombreMes %></div>
      <div style="font-size:11px;color:#888888;font-family:Arial, sans-serif;">
        <%= nombreNegocio %> &middot; CUIT <%= cuit %> &middot; <%= condicionLabel %> Cat. <%= categoria %>
      </div>
    </td>
  </tr>

  <!-- ================= STATS (3 columnas) ================= -->
  <tr>
    <td class="koi-px" style="background-color:#fafaf8;padding:10px 16px;border-bottom:1px solid #f0ede8;">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
          <td class="koi-stat-cell" width="33.33%" align="left" valign="top" style="padding:0 12px 0 0;border-right:1px solid #eee;">
            <div style="font-size:9px;color:#aaaaaa;text-transform:uppercase;letter-spacing:0.4px;font-weight:500;font-family:Arial, sans-serif;margin-bottom:3px;">Total facturado</div>
            <div style="font-size:16px;font-weight:700;color:#111111;font-family:Arial, sans-serif;letter-spacing:-0.3px;">$<%= totalFacturado.toLocaleString('es-AR') %></div>
            <div style="font-size:10px;color:#888888;font-family:Arial, sans-serif;margin-top:2px;"><%= totalComprobantes %> comprobantes</div>
          </td>
          <%
            const _facturacionAcumulada = typeof facturacionAcumulada !== 'undefined' ? facturacionAcumulada : totalFacturado;
            const _limiteAnual = typeof limiteAnual !== 'undefined' ? limiteAnual : limiteCategoria;
            const _porcentajeAnual = typeof porcentajeAnual !== 'undefined' ? porcentajeAnual : porcentaje;
            const _pendientesCAE = typeof pendientesCAE !== 'undefined'
              ? pendientesCAE
              : orders.filter(o => o.status === 'pending_invoice' || o.status === 'error_afip').length;
          %>
          <td class="koi-stat-cell" width="33.33%" align="left" valign="top" style="padding:0 12px;border-right:1px solid #eee;">
            <div style="font-size:9px;color:#aaaaaa;text-transform:uppercase;letter-spacing:0.4px;font-weight:500;font-family:Arial, sans-serif;margin-bottom:3px;">Acum. 12 meses</div>
            <div style="font-size:16px;font-weight:700;color:#111111;font-family:Arial, sans-serif;letter-spacing:-0.3px;">$<%= _facturacionAcumulada.toLocaleString('es-AR') %></div>
            <div style="font-size:10px;color:#888888;font-family:Arial, sans-serif;margin-top:2px;"><%= _porcentajeAnual.toFixed(1) %>% del l&iacute;mite</div>
          </td>
          <td class="koi-stat-cell" width="33.33%" align="left" valign="top" style="padding:0 0 0 12px;">
            <div style="font-size:9px;color:#aaaaaa;text-transform:uppercase;letter-spacing:0.4px;font-weight:500;font-family:Arial, sans-serif;margin-bottom:3px;">Pendientes CAE</div>
            <div style="font-size:16px;font-weight:700;color:#e05500;font-family:Arial, sans-serif;letter-spacing:-0.3px;"><%= _pendientesCAE %></div>
            <div style="font-size:10px;color:#888888;font-family:Arial, sans-serif;margin-top:2px;">Requiere atenci&oacute;n</div>
          </td>
        </tr>
      </table>
    </td>
  </tr>

  <!-- ================= NOTA (opcional) ================= -->
  <% if (nota && nota.trim()) { %>
  <tr>
    <td class="koi-px" style="padding:10px 16px;border-bottom:1px solid #f0ede8;">
      <div style="font-size:9px;color:#aaaaaa;text-transform:uppercase;letter-spacing:0.4px;font-weight:500;font-family:Arial, sans-serif;margin-bottom:4px;">Nota de <%= nombreNegocio %></div>
      <div style="font-size:11px;color:#555555;font-style:italic;line-height:1.5;font-family:Arial, sans-serif;"><%= nota %></div>
    </td>
  </tr>
  <% } %>

  <!-- ================= TABLA DE COMPROBANTES (condicional) ================= -->
  <% if (typeof incluirComprobantes === 'undefined' || incluirComprobantes !== false) { %>
  <tr>
    <td class="koi-px" style="padding:8px 16px;border-bottom:1px solid #f0ede8;">
      <div style="font-size:11px;font-weight:600;color:#333333;font-family:Arial, sans-serif;">Comprobantes emitidos &middot; <%= nombreMes %></div>
    </td>
  </tr>
  <tr>
    <td>
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="font-size:10px;">
        <thead>
          <tr style="background-color:#fafaf8;">
            <th align="left" style="padding:4px 8px 4px 16px;font-size:9px;color:#aaaaaa;font-weight:500;text-transform:uppercase;letter-spacing:0.3px;font-family:Arial, sans-serif;">N&deg; Comp.</th>
            <th align="left" style="padding:4px 8px;font-size:9px;color:#aaaaaa;font-weight:500;text-transform:uppercase;letter-spacing:0.3px;font-family:Arial, sans-serif;">Cliente</th>
            <th align="left" style="padding:4px 8px;font-size:9px;color:#aaaaaa;font-weight:500;text-transform:uppercase;letter-spacing:0.3px;font-family:Arial, sans-serif;">CAE</th>
            <th align="left" style="padding:4px 8px;font-size:9px;color:#aaaaaa;font-weight:500;text-transform:uppercase;letter-spacing:0.3px;font-family:Arial, sans-serif;">Vto. CAE</th>
            <th align="right" style="padding:4px 16px 4px 8px;font-size:9px;color:#aaaaaa;font-weight:500;text-transform:uppercase;letter-spacing:0.3px;font-family:Arial, sans-serif;">Monto</th>
          </tr>
        </thead>
        <tbody>
          <% if (orders.length > 0) { %>
            <% orders.forEach((o, i) => {
              const nroComp = o.nroFormatted || o.externalId || '—';
              const cliente = o.customerName || 'Sin nombre';
              const monto = (o.amount || 0).toLocaleString('es-AR');
              const caeDisplay = o.caeNumber || '—';
              const caeVto = o.caeExpiry ? new Date(o.caeExpiry).toLocaleDateString('es-AR', { day: '2-digit', month: '2-digit', year: 'numeric' }) : '—';
              const rowBg = i % 2 === 0 ? '#ffffff' : '#fafaf8';
            %>
            <tr style="background-color:<%= rowBg %>;">
              <td style="padding:4px 8px 4px 16px;font-size:9px;color:#333333;font-weight:500;border-top:1px solid #f4f2ee;font-family:Arial, sans-serif;"><%= nroComp %></td>
              <td style="padding:4px 8px;font-size:9px;color:#555555;border-top:1px solid #f4f2ee;font-family:Arial, sans-serif;"><%= cliente %></td>
              <td style="padding:4px 8px;font-size:9px;color:#888888;border-top:1px solid #f4f2ee;font-family:'Courier New',monospace;"><%= caeDisplay %></td>
              <td style="padding:4px 8px;font-size:9px;color:#888888;border-top:1px solid #f4f2ee;font-family:Arial, sans-serif;"><%= caeVto %></td>
              <td align="right" style="padding:4px 16px 4px 8px;font-size:9px;color:#111111;font-weight:600;border-top:1px solid #f4f2ee;font-family:Arial, sans-serif;">$<%= monto %></td>
            </tr>
            <% }); %>
            <tr style="background-color:#fff8f5;border-top:2px solid #e8e6e0;">
              <td colspan="4" style="padding:8px 8px 8px 16px;font-size:11px;font-weight:600;color:#333333;font-family:Arial, sans-serif;">Total del per&iacute;odo</td>
              <td align="right" style="padding:8px 16px 8px 8px;font-size:13px;font-weight:700;color:#e05500;font-family:Arial, sans-serif;">$<%= totalFacturado.toLocaleString('es-AR') %></td>
            </tr>
          <% } else { %>
            <tr>
              <td colspan="5" align="center" style="padding:24px 16px;font-size:11px;color:#888888;font-family:Arial, sans-serif;">No hay comprobantes emitidos en este per&iacute;odo</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </td>
  </tr>
  <% } %>

  <!-- ================= POSICIÓN EN CATEGORÍA (condicional) ================= -->
  <% if (typeof incluirCategoria === 'undefined' || incluirCategoria !== false) { %>
  <tr>
    <td class="koi-px" style="padding:10px 16px;border-top:1px solid #f0ede8;">
      <div style="font-size:11px;font-weight:600;color:#333333;font-family:Arial, sans-serif;margin-bottom:8px;">Posici&oacute;n en categor&iacute;a</div>

      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
          <td style="font-size:10px;color:#888888;font-family:Arial, sans-serif;padding-bottom:4px;">Facturado &uacute;ltimos 12 meses</td>
          <td align="right" style="font-size:10px;color:#333333;font-weight:500;font-family:Arial, sans-serif;padding-bottom:4px;">$<%= _facturacionAcumulada.toLocaleString('es-AR') %></td>
        </tr>
        <tr>
          <td style="font-size:10px;color:#888888;font-family:Arial, sans-serif;padding-bottom:4px;">L&iacute;mite Categor&iacute;a <%= categoria %></td>
          <td align="right" style="font-size:10px;color:#333333;font-weight:500;font-family:Arial, sans-serif;padding-bottom:4px;">$<%= _limiteAnual.toLocaleString('es-AR', { maximumFractionDigits: 2 }) %></td>
        </tr>
      </table>

      <!-- Barra de progreso "bulletproof" con tabla anidada -->
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:4px 0;">
        <tr>
          <td style="background-color:#eeeeee;border-radius:4px;">
            <table role="presentation" width="100%" height="5" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <% const pct = Math.max(0, Math.min(Math.round(_porcentajeAnual), 100)); %>
                <% if (pct > 0) { %><td width="<%= pct %>%" style="background-color:#3db87a;font-size:1px;line-height:5px;border-radius:4px;">&nbsp;</td><% } %>
                <% if (pct < 100) { %><td width="<%= 100 - pct %>%" style="font-size:1px;line-height:5px;">&nbsp;</td><% } %>
              </tr>
            </table>
          </td>
        </tr>
      </table>

      <%
        const _margen = typeof margen !== 'undefined' ? margen : (_limiteAnual - _facturacionAcumulada);
      %>
      <div style="font-size:10px;color:#3a7a55;font-weight:600;font-family:Arial, sans-serif;">
        <%= _porcentajeAnual.toFixed(1) %>% utilizado &middot; Margen disponible: $<%= _margen.toLocaleString('es-AR', { maximumFractionDigits: 2 }) %>
      </div>
    </td>
  </tr>
  <% } %>

  <!-- ================= FOOTER ================= -->
  <tr>
    <td class="koi-px" align="center" style="font-size:9px;color:#bbbbbb;text-align:center;padding:10px 16px;border-top:1px solid #f0ede8;font-family:Arial, sans-serif;">
      Generado autom&aacute;ticamente por KOI &middot; koi-factura.lat &middot; Los datos son de car&aacute;cter informativo
      <% if (contadorNombre) { %><br>Enviado a: <%= contadorNombre %><% } %>
    </td>
  </tr>

</table>

</td>
</tr>
</table>
</body>
</html>