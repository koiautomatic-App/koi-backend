<!-- views/reporte.ejs -->
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reporte Mensual - <%= nombreMes %></title>
    <style>
        /* ===== KOI ESTILOS - IGUAL QUE EL DASHBOARD ===== */
        :root {
            --bg: #080810;
            --bg-2: #0d0d1a;
            --surface: #111120;
            --card: #13131f;
            --card-2: #17172a;
            --border: rgba(255,255,255,0.055);
            --green: #00e676;
            --green-glow: rgba(0,230,118,0.18);
            --green-soft: rgba(0,230,118,0.08);
            --orange: #e8622a;
            --orange-2: #f5a623;
            --orange-glow: rgba(232,98,42,0.22);
            --orange-soft: rgba(232,98,42,0.10);
            --red: #ff3d57;
            --yellow: #ffb300;
            --text-1: #f0f0fa;
            --text-2: #8888aa;
            --text-3: #44445a;
            --font-ui: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif;
            --font-num: 'Space Grotesk', monospace;
            --r-sm: 8px; --r-md: 14px; --r-lg: 18px; --r-xl: 24px;
        }
        
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { 
            background: var(--bg);
            color: var(--text-1);
            font-family: var(--font-ui);
            font-size: 13px;
            line-height: 1.5;
            padding: 20px;
            min-height: 100vh;
        }
        
        .container {
            max-width: 900px;
            margin: 0 auto;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r-xl);
            overflow: hidden;
            box-shadow: 0 4px 24px rgba(0,0,0,0.5);
        }
        
        /* ===== HEADER ===== */
        .header {
            background: var(--card-2);
            padding: 28px 32px;
            border-bottom: 3px solid var(--green);
            position: relative;
        }
        .header::after {
            content: '';
            position: absolute;
            top: -60px;
            right: -60px;
            width: 220px;
            height: 220px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(232,98,42,0.05) 0%, rgba(0,230,118,0.04) 60%, transparent 100%);
            pointer-events: none;
        }
        .header-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
        }
        .header-brand {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .header-brand .logo-mark {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: linear-gradient(135deg, var(--orange), var(--orange-2), var(--green));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            font-weight: 900;
            color: #fff;
            flex-shrink: 0;
        }
        .header-brand .logo-text {
            font-weight: 800;
            font-size: 18px;
            color: var(--text-1);
            letter-spacing: -0.3px;
        }
        .header-brand .logo-text span {
            color: var(--green);
        }
        .header-brand .logo-sub {
            font-size: 9px;
            font-weight: 500;
            color: var(--text-3);
            letter-spacing: 1.4px;
            text-transform: uppercase;
        }
        .header-badge {
            background: var(--green-soft);
            border: 1px solid rgba(0,230,118,0.2);
            padding: 4px 14px;
            border-radius: 999px;
            font-size: 10px;
            font-weight: 700;
            color: var(--green);
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }
        .header h1 {
            font-size: 24px;
            font-weight: 700;
            color: var(--text-1);
            letter-spacing: -0.5px;
            margin-bottom: 2px;
        }
        .header .sub {
            font-size: 14px;
            color: var(--text-2);
        }
        .header .meta {
            display: flex;
            gap: 12px;
            margin-top: 12px;
            flex-wrap: wrap;
        }
        .header .meta-item {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 11px;
            color: var(--text-3);
            background: rgba(255,255,255,0.03);
            padding: 4px 14px;
            border-radius: 999px;
            border: 1px solid var(--border);
        }
        .header .meta-item strong {
            color: var(--text-1);
            font-weight: 600;
        }

        /* ===== STATS ===== */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 12px;
            padding: 20px 32px;
            background: var(--bg-2);
            border-bottom: 1px solid var(--border);
        }
        .stat-card {
            text-align: center;
            padding: 8px 4px;
        }
        .stat-card .number {
            font-family: var(--font-num);
            font-size: 28px;
            font-weight: 700;
            color: var(--green);
            letter-spacing: -1px;
        }
        .stat-card .number.warn {
            color: var(--yellow);
        }
        .stat-card .label {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--text-3);
            margin-top: 4px;
        }
        .stat-card .sub {
            font-size: 10px;
            color: var(--text-3);
            margin-top: 2px;
        }

        /* ===== CONTENT ===== */
        .content {
            padding: 24px 32px;
        }

        /* Nota */
        .nota-box {
            background: rgba(255,179,0,0.06);
            border-left: 3px solid var(--yellow);
            padding: 14px 18px;
            border-radius: var(--r-sm);
            margin-bottom: 24px;
        }
        .nota-box .label {
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--yellow);
            margin-bottom: 2px;
        }
        .nota-box p {
            font-size: 13px;
            color: var(--text-2);
            margin: 0;
        }

        /* Tabla */
        .table-title {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 14px;
        }
        .table-title h3 {
            font-size: 14px;
            font-weight: 700;
            color: var(--text-1);
        }
        .table-title .count {
            background: var(--card-2);
            color: var(--text-2);
            padding: 0 12px;
            border-radius: 999px;
            font-size: 11px;
            font-weight: 600;
            border: 1px solid var(--border);
        }

        .table-wrapper {
            overflow-x: auto;
            border: 1px solid var(--border);
            border-radius: var(--r-md);
            margin-bottom: 24px;
            background: var(--card-2);
        }
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12px;
        }
        thead {
            background: rgba(232,98,42,0.04);
            border-bottom: 1px solid rgba(232,98,42,0.1);
        }
        thead th {
            padding: 10px 14px;
            text-align: left;
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: rgba(232,98,42,0.5);
            border-bottom: 1px solid var(--border);
        }
        thead th:last-child {
            text-align: right;
        }
        td {
            padding: 9px 14px;
            color: var(--text-1);
            border-bottom: 1px solid var(--border);
        }
        td:last-child {
            text-align: right;
            font-weight: 600;
            color: var(--green);
        }
        .mono {
            font-family: var(--font-num);
            font-size: 11px;
            color: var(--text-2);
        }
        .date {
            color: var(--text-3);
            font-size: 11px;
        }
        tr.alt td {
            background: rgba(255,255,255,0.02);
        }
        tr.total td {
            background: var(--green-soft);
            border-top: 2px solid var(--green);
            font-weight: 700;
            color: var(--text-1);
        }
        tr.total td:last-child {
            font-size: 14px;
            color: var(--green);
        }
        .empty-state {
            padding: 30px;
            text-align: center;
            color: var(--text-3);
        }

        /* Categoría */
        .categoria-section {
            background: var(--green-soft);
            border: 1px solid rgba(0,230,118,0.12);
            border-radius: var(--r-md);
            padding: 18px 24px;
            margin-bottom: 8px;
        }
        .categoria-section .title {
            font-weight: 700;
            font-size: 13px;
            color: var(--text-1);
            margin-bottom: 10px;
        }
        .cat-row {
            display: flex;
            justify-content: space-between;
            padding: 3px 0;
            font-size: 12px;
        }
        .cat-row .label {
            color: var(--text-2);
        }
        .cat-row .value {
            font-weight: 600;
            color: var(--text-1);
        }
        .progress-bar {
            width: 100%;
            height: 6px;
            background: rgba(255,255,255,0.05);
            border-radius: 999px;
            margin: 10px 0;
            overflow: hidden;
        }
        .progress-bar .fill {
            height: 100%;
            background: linear-gradient(90deg, var(--orange), var(--orange-2), var(--green));
            border-radius: 999px;
            transition: width 0.6s ease;
        }
        .cat-pct {
            font-size: 11px;
            color: var(--text-2);
            font-weight: 500;
        }
        .cat-pct strong {
            color: var(--green);
        }

        /* FOOTER */
        .footer {
            padding: 16px 32px;
            background: var(--bg-2);
            border-top: 1px solid var(--border);
            text-align: center;
        }
        .footer p {
            font-size: 11px;
            color: var(--text-3);
        }
        .footer .brand {
            color: var(--green);
            font-weight: 700;
        }
        .footer .sub {
            font-size: 10px;
            color: var(--text-3);
            margin-top: 4px;
        }
        .footer .sub strong {
            color: var(--text-2);
        }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 640px) {
            body { padding: 12px; }
            .header { padding: 20px; }
            .header h1 { font-size: 20px; }
            .stats-grid { 
                grid-template-columns: repeat(2, 1fr); 
                gap: 8px; 
                padding: 16px 20px; 
            }
            .stat-card .number { font-size: 22px; }
            .content { padding: 16px 20px; }
            .footer { padding: 12px 20px; }
            table { font-size: 10px; }
            thead th, td { padding: 6px 10px; }
            .header .meta { gap: 6px; }
            .header .meta-item { font-size: 10px; padding: 2px 10px; }
            .cat-row { font-size: 11px; }
            .categoria-section { padding: 14px 16px; }
        }
        @media (max-width: 400px) {
            .stats-grid { grid-template-columns: 1fr 1fr; gap: 6px; }
            .stat-card .number { font-size: 18px; }
            .header-brand .logo-text { font-size: 14px; }
            .header-brand .logo-mark { width: 32px; height: 32px; font-size: 16px; }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- HEADER -->
        <div class="header">
            <div class="header-top">
                <div class="header-brand">
                    <div class="logo-mark">K</div>
                    <div>
                        <div class="logo-text">KOI<span>·FACTURA</span></div>
                        <div class="logo-sub">sono.handmade · AFIP</div>
                    </div>
                </div>
                <div class="header-badge">Reporte Mensual</div>
            </div>
            <h1><%= nombreMes %></h1>
            <div class="sub"><%= nombreNegocio %></div>
            <div class="meta">
                <span class="meta-item">📋 <strong><%= condicionLabel %></strong></span>
                <span class="meta-item">📊 Cat. <strong><%= categoria %></strong></span>
                <span class="meta-item">🆔 CUIT <strong><%= cuit %></strong></span>
            </div>
        </div>

        <!-- STATS -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="number">$<%= totalFacturado.toLocaleString('es-AR') %></div>
                <div class="label">Total Facturado</div>
                <div class="sub"><%= totalComprobantes %> comprobantes</div>
            </div>
            <div class="stat-card">
                <div class="number"><%= totalComprobantes %></div>
                <div class="label">Comprobantes Emitidos</div>
                <div class="sub">En el período</div>
            </div>
            <div class="stat-card">
                <div class="number"><%= porcentaje.toFixed(1) %>%</div>
                <div class="label">Límite Cat. <%= categoria %></div>
                <div class="sub"><%= totalComprobantes > 0 ? 'Utilizado' : 'Sin actividad' %></div>
            </div>
            <div class="stat-card">
                <div class="number"><%= totalComprobantes > 0 ? '✅' : '📋' %></div>
                <div class="label">Pendientes CAE</div>
                <div class="sub"><%= totalComprobantes > 0 ? 'Todas emitidas' : 'Sin emitir' %></div>
            </div>
        </div>

        <!-- CONTENT -->
        <div class="content">
            <!-- NOTA -->
            <% if (nota && nota.trim()) { %>
                <div class="nota-box">
                    <div class="label">📝 Nota</div>
                    <p><%= nota %></p>
                </div>
            <% } %>

            <!-- TABLA -->
            <div class="table-title">
                <h3>📄 Detalle de Comprobantes</h3>
                <span class="count"><%= orders.length %></span>
            </div>
            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th>N° Comprobante</th>
                            <th>Cliente</th>
                            <th>CAE</th>
                            <th>Vto. CAE</th>
                            <th style="text-align: right;">Monto</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (orders.length > 0) { %>
                            <% orders.forEach((o, i) => { 
                                const nroComp = o.nroFormatted || o.externalId || '—';
                                const cliente = o.customerName || 'Sin nombre';
                                const fecha = o.createdAt ? new Date(o.createdAt).toLocaleDateString('es-AR', { day: '2-digit', month: '2-digit', year: 'numeric' }) : '—';
                                const monto = (o.amount || 0).toLocaleString('es-AR');
                                const caeDisplay = o.caeNumber || '—';
                                const caeVto = o.caeExpiry ? new Date(o.caeExpiry).toLocaleDateString('es-AR', { day: '2-digit', month: '2-digit', year: 'numeric' }) : '—';
                                const altClass = i % 2 === 0 ? '' : 'alt';
                            %>
                                <tr class="<%= altClass %>">
                                    <td><%= nroComp %></td>
                                    <td><%= cliente %></td>
                                    <td class="mono"><%= caeDisplay %></td>
                                    <td class="date"><%= caeVto %></td>
                                    <td>$<%= monto %></td>
                                </tr>
                            <% }); %>
                            <tr class="total">
                                <td colspan="4">Total del período</td>
                                <td>$<%= totalFacturado.toLocaleString('es-AR') %></td>
                            </tr>
                        <% } else { %>
                            <tr>
                                <td colspan="5" class="empty-state">
                                    No hay comprobantes emitidos en este período
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <!-- CATEGORÍA -->
            <div class="categoria-section">
                <div class="title">📈 Posición en categoría</div>
                <div class="cat-row">
                    <span class="label">Facturado últimos 12 meses</span>
                    <span class="value">$<%= totalFacturado.toLocaleString('es-AR') %></span>
                </div>
                <div class="cat-row">
                    <span class="label">Límite Categoría <%= categoria %></span>
                    <span class="value">$<%= limiteCategoria.toLocaleString('es-AR', { maximumFractionDigits: 2 }) %></span>
                </div>
                <div class="progress-bar">
                    <div class="fill" style="width: <%= Math.min(porcentaje, 100) %>%;"></div>
                </div>
                <div class="cat-pct">
                    <strong><%= porcentaje.toFixed(1) %>%</strong> utilizado · Margen disponible: <strong>$<%= margen.toLocaleString('es-AR', { maximumFractionDigits: 2 }) %></strong>
                </div>
            </div>
        </div>

        <!-- FOOTER -->
        <div class="footer">
            <p>
                Generado automáticamente por <strong class="brand">KOI</strong> · 
                <span style="color: var(--text-3);">koi-factura.lat</span>
            </p>
            <p class="sub">
                <% if (contadorNombre) { %>Enviado por: <strong><%= contadorNombre %></strong><% } %>
                <% if (contadorNombre) { %> · <% } %>
                Los datos son de carácter informativo
            </p>
        </div>
    </div>
</body>
</html>